    },
    {
      "id": "af3aazTvICsu8lCOX9tQs",
      "type": "text",
      "x": 1663.4840588052123,
      "y": 441.7085639335306,
      "width": 143.69659423828125,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
