      "index": "b0A",
      "roundness": null,
      "seed": 1927912543,
      "version": 147,
      "versionNonce": 871496863,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783107787057,
      "link": null,
      "locked": false,
      "text": "Drawbacks",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Drawbacks",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9saTTnlF5Pcl6meOZ8OaR",
      "type": "text",
      "x": 1663.4850838973302,
      "y": 491.82736777535195,
      "width": 538.5821533203125,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0B",
      "roundness": null,
      "seed": 488852159,
      "version": 576,
      "versionNonce": 518459583,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783107787057,
      "link": null,
      "locked": false,
      "text": "In this approach time interval is fixed so any user can\ntrick the system\n\nBy making reqs at the very end of \n1st sec and the beginning of next sec\n\nWhich can bring system down intentionally or\nunknowingly ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In this approach time interval is fixed so any user can trick the system\n\nBy making reqs at the very end of \n1st sec and the beginning of next sec\n\nWhich can bring system down intentionally or unknowingly ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "1bjBFAET3LlT5jdBNeCmC",
      "type": "text",
      "x": 1659.5622731701203,
      "y": 733.1181660157366,
      "width": 281.79315185546875,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
