    },
    {
      "id": "SvW5Zh6H5EKWZWk5TBiz5",
      "type": "text",
      "x": 1659.0118271201925,
      "y": 779.547470443165,
      "width": 467.3996276855469,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0D",
      "roundness": null,
      "seed": 1725076145,
      "version": 572,
      "versionNonce": 1651402164,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783108880187,
      "link": null,
      "locked": false,
      "text": "UserId (8 bytes)\nTimestamp (4 bytes) epoch only min & secs\nCounter (2 bytes)\nHT(overhead)  (20 bytes)\n\nSo total memory per user will be : 34 bytes\n\nLet's assume we have 1M DAU, to handle \nthis much amount of users we need ~34 MB ram\nto store this data in-memory",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "UserId (8 bytes)\nTimestamp (4 bytes) epoch only min & secs\nCounter (2 bytes)\nHT(overhead)  (20 bytes)\n\nSo total memory per user will be : 34 bytes\n\nLet's assume we have 1M DAU, to handle \nthis much amount of users we need ~34 MB ram\nto store this data in-memory",
      "autoResize": true,
      "lineHeight": 1.25
    }
  ],
