      "versionNonce": 288518291,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770023822137,
      "link": null,
      "locked": false,
      "text": "Messaging Scenario -\n1) User A tries to sends message to\nOther user, first user A send MSG to its\nserver where user A connection exists \nThen this msg is route to receiver\nServer where it has other users\nConnection through hash table\nLookup.\n2) after routing messages to receiver server \nIt sends acknowledgement(server-server) to\nSender server and deliver it to the receiver,\nonce msg received to the user, we send msg received \nacknowledgement to server & confirm msg sent",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Messaging Scenario -\n1) User A tries to sends message to\nOther user, first user A send MSG to its\nserver where user A connection exists \nThen this msg is route to receiver\nServer where it has other users\nConnection through hash table\nLookup.\n2) after routing messages to receiver server \nIt sends acknowledgement(server-server) to\nSender server and deliver it to the receiver,\nonce msg received to the user, we send msg received \nacknowledgement to server & confirm msg sent",
      "autoResize": true,
      "lineHeight": 1.25
    },
