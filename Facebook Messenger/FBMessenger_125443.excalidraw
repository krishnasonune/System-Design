    {
      "id": "mpGYJdY1-apWOfbKHyIov",
      "type": "text",
      "x": 1620.3372402613927,
      "y": -328.5268267064039,
      "width": 792.6123046875,
      "height": 405,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3r",
      "roundness": null,
      "seed": 259152216,
      "version": 665,
      "versionNonce": 1347764356,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770018185989,
      "link": null,
      "locked": false,
      "text": "Event Streaming -\n1) when user is offline, we won't be having\nConnection obj in Hashtable on chat server\nIn that case we'll enqueue those messages in\nQueue which is very durable choice, once user\nBacks online we can process all the pending \nmessages and send it to user.\n2) we can also use dedicated queue for\nbroadcasting & managing User Active status",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Event Streaming -\n1) when user is offline, we won't be having\nConnection obj in Hashtable on chat server\nIn that case we'll enqueue those messages in\nQueue which is very durable choice, once user\nBacks online we can process all the pending \nmessages and send it to user.\n2) we can also use dedicated queue for\nbroadcasting & managing User Active status",
      "autoResize": true,
      "lineHeight": 1.25
    },
