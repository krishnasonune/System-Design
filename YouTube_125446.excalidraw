      "boundElements": [],
      "updated": 1776025403565,
      "link": null,
      "locked": false,
      "text": "Video Service\n- it responsible to handle/serves api\n  request/response for view/search/upload.\n- on successful upload request we update \n  Video metadata & publish message to queue\n  with video details for further processing.\n- on successful search request we return data\n  like video metadata (video DB) & Thumbnails(Big Table), \n  but default query limit is 20 per request \n- on successful view request we fetch exactly \n  specific video metadata & video url from blob\n  storage ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Video Service\n- it responsible to handle/serves api\n  request/response for view/search/upload.\n- on successful upload request we update \n  Video metadata & publish message to queue\n  with video details for further processing.\n- on successful search request we return data\n  like video metadata (video DB) & Thumbnails(Big Table), \n  but default query limit is 20 per request \n- on successful view request we fetch exactly \n  specific video metadata & video url from blob\n  storage ",
      "autoResize": true,
      "lineHeight": 1.25
    },
