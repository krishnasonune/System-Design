      "text": "Process events emitted by watcher,\n( like create/update/delete) file,\nalso upload/download file, and\nupdate internal metadata db and\nremote metadata",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Process events emitted by watcher,  \n( like create/update/delete) file, also upload/download file, and update internal metadata db and remote metadata",
      "autoResize": false,
      "lineHeight": 1.25
    },
